	(text "ACT is ac condenser thermistor (ntc), input to ecu\nAC1 is 12v signal from ac computer to ecu, telling it ac has been switched on (for idle up)\nAC2 is signal from ecu to ac computer, telling it to engage clutch (allow ecu to disengage e.g full throttle)"
		(exclude_from_sim no)
		(at 50.292 207.01 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "035c386e-2e4e-44d8-bff5-d313bcfaced4")
	)
	(text "Lowside drivers for various relays / solenoids\nFlyback diode used"
		(exclude_from_sim no)
		(at 54.102 64.008 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "7b67daae-5359-429f-b1d7-c60d186a4ddf")
	)
	(text "Lowside drivers for 4 injectors\nNo flyblack diode as we need rapid demagnetization"
		(exclude_from_sim no)
		(at 55.118 17.78 0)
